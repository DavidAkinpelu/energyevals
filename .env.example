# =============================================================================
# EnergyEvals Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers (at least one required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPINFRA_API_KEY=...
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Standard Tools APIs (optional - tools will warn if missing)
# -----------------------------------------------------------------------------

# Exa Search (for SearchTool)
EXA_API_KEY=...

# Grid Status API (for GridStatusTool)
GRIDSTATUS_API_KEY=...

# OpenEI Utility Rates (for TariffsTool)
OPEN_EI_API_KEY=...

# Renewables Ninja (for RenewablesTool)
RENEWABLES_NINJA_API_KEY=...

# Openweather (for OpenweatherTool)
OPENWEATHER_API_KEY=...

# New York DPS (for NewYorkDocketTool)
NY_DPS_TOKEN=...

# -----------------------------------------------------------------------------
# MCP Servers (for RAG and database tools)
# -----------------------------------------------------------------------------
RAG_SERVER_URL=https://energyevals-rag-mcp.tume.ai/sse
DATABASE_SERVER_URL=https://energyevals-db-mcp.tume.ai/sse
